---
layout: base.njk
pagination:
  data: children
  size: 1
  alias: child
permalink: "/{{ child.id }}/"
eleventyComputed:
  title: "{{ child.statement }} | AI Sense"
---

<a href="{{ ('/' + child.parentId + '/') | url }}" class="back-link">&larr; {{ child.parentStatement }}</a>

<div class="post-header">
  <h1 class="post-title">{{ child.statement }}</h1>
</div>

<div class="post-content">
  <p>{{ child.explanation }}</p>
</div>

{% if child.terms and child.terms | length %}
<div class="section" style="margin-top: var(--spacing-9);">
  <div class="section-title">Key Terms</div>
  <div class="terms-grid">
    {% for word, def in child.terms %}
    <div class="term-card">
      <p class="term-word">{{ word }}</p>
      <p class="term-def">{{ def }}</p>
    </div>
    {% endfor %}
  </div>
</div>
{% endif %}
