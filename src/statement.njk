---
layout: base.njk
pagination:
  data: aisense.statements
  size: 1
  alias: item
permalink: "/{{ item.id }}/"
eleventyComputed:
  title: "{{ item.statement }} | AI Sense"
---

<a href="{{ '/' | url }}" class="back-link">&larr; All senses</a>

{% set idx = 0 %}
{% for s in aisense.statements %}
  {% if s.id == item.id %}{% set idx = loop.index %}{% endif %}
{% endfor %}

<div class="post-header">
  <span class="post-label">Sense {{ idx }} of {{ aisense.statements | length }}</span>
  <h1 class="post-title">{{ item.statement }}</h1>
</div>

<div class="post-content">
  {{ item.explanation | replace("\n\n", "</p><p>") | replace("\n", " ") | safe }}
</div>

{% if item.image %}
<div class="post-image">
  <img src="{{ item.image | url }}" alt="{{ item.imageAlt or item.statement }}" loading="lazy" onclick="this.closest('.post-image').classList.toggle('zoomed')" />
</div>
{% endif %}

{% if item.experiment %}
<div class="section" style="margin-top: var(--spacing-9);">
  <div class="section-title">Try It Yourself</div>
  <p style="color: var(--color-foreground); font-size: var(--font-small); margin-bottom: var(--spacing-5);">{{ item.experiment.intro }}</p>
  <div class="experiment-grid">
    {% for p in item.experiment.prompts %}
    <div class="experiment-card">
      <span class="experiment-label">{{ p.label }}</span>
      <p class="experiment-text">{{ p.text }}</p>
      <a href="{{ p.link }}" target="_blank" rel="noopener" class="button experiment-button">Try in ChatGPT &rarr;</a>
    </div>
    {% endfor %}
  </div>
  {% if item.experiment.result %}
  <div class="experiment-result">
    {{ item.experiment.result | replace("\n\n", "</p><p>") | replace("\n", " ") | safe }}
  </div>
  {% endif %}
</div>
{% endif %}

{% if item.terms and item.terms | length %}
<div class="section" style="margin-top: var(--spacing-9);">
  <div class="section-title">Key Terms</div>
  <div class="terms-grid">
    {% for word, def in item.terms %}
    <div class="term-card">
      <p class="term-word">{{ word }}</p>
      <p class="term-def">{{ def }}</p>
    </div>
    {% endfor %}
  </div>
</div>
{% endif %}

{% if item.children and item.children | length %}
<div class="section" style="margin-top: var(--spacing-9);">
  <div class="section-title">Go Deeper</div>
  <div class="section-list">
    {% for child in item.children %}
    <article class="card">
      <a class="card-link" href="{{ ('/' + child.id + '/') | url }}" aria-label="{{ child.statement }}"></a>
      <div class="card-content">
        <div class="card-header">
          <h3 class="card-title">{{ child.statement }}</h3>
        </div>
        <p class="card-excerpt">{{ child.explanation }}</p>
      </div>
    </article>
    {% endfor %}
  </div>
</div>
{% endif %}

<nav class="post-nav" aria-label="Sense navigation">
  {% set prevIdx = idx - 2 %}
  {% set nextIdx = idx %}
  {% if prevIdx >= 0 %}
  <a href="{{ ('/' + aisense.statements[prevIdx].id + '/') | url }}">
    &larr; {{ aisense.statements[prevIdx].statement | truncate(40) }}
  </a>
  {% else %}
  <span></span>
  {% endif %}
  {% if nextIdx < aisense.statements | length %}
  <a href="{{ ('/' + aisense.statements[nextIdx].id + '/') | url }}" style="text-align: right;">
    {{ aisense.statements[nextIdx].statement | truncate(40) }} &rarr;
  </a>
  {% else %}
  <span></span>
  {% endif %}
</nav>
